---
import '../styles/site.css';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gallery | Birchwood Boarding Kennels</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/P3524/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/P3524/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-black py-2 px-4 text-center text-sm">
      <div class="max-w-4xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span>Preview for <strong>Birchwood Boarding Kennels</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=P3524&name=Birchwood%20Boarding%20Kennels" class="inline-flex items-center px-4 py-1 bg-black text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-brand-bg/95 backdrop-blur-sm border-b border-white/10 sticky top-0 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/P3524" class="font-display font-extrabold text-xl text-white">🐾 Birchwood Boarding Kennels</a>
        <button class="md:hidden p-2 text-white/70" onclick="document.getElementById('mobile-nav-P3524').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/P3524" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Home</a>
          <a href="/P3524/services" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Services</a>
          <a href="/P3524/gallery" class="text-sm text-brand-accent font-semibold transition-colors">Gallery</a>
          <a href="/P3524/contact" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Contact</a>
          <a href="/P3524/contact" class="inline-flex items-center px-5 py-2 bg-brand-accent text-black font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">Get in touch</a>
        </nav>
      </div>
      <nav id="mobile-nav-P3524" class="hidden md:hidden px-6 pb-4 space-y-3">
        <a href="/P3524" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Home</a>
        <a href="/P3524/services" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Services</a>
        <a href="/P3524/gallery" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Gallery</a>
        <a href="/P3524/contact" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Contact</a>
        <a href="/P3524/contact" class="block px-5 py-2.5 bg-brand-accent text-black font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">Get in touch</a>
      </nav>
    </header>


    <section class="relative py-20 sm:py-28 overflow-hidden">
      <img src="/P3524/images/119933414-2004354253033873-3162195168049-3.jpg" alt="" class="absolute inset-0 w-full h-full object-cover z-[1]" loading="lazy" />
      <div class="absolute inset-0 z-[2] bg-black/60"></div>
      <div class="relative z-[3] mx-auto max-w-4xl px-6">
        <h1 class="font-display font-extrabold text-4xl sm:text-5xl text-white">Gallery</h1>
        <p class="mt-4 text-white/70 text-lg">Birchwood Boarding Kennels in action.</p>
      </div>
    </section>

    <section class="bg-brand-bg border-y border-white/5 py-20">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-white mb-10 text-center">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/510576472-3508512225951394-3562635743975-2.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/119933414-2004354253033873-3162195168049-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/120065753-2004354243033874-2413520240679-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71773928-1638202129649089-52782207046034-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71271171-1638202599649042-63799200770508-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/72165265-1651841874951781-43132106420361-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71096337-1638202199649082-59970197654727-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71472462-1638202149649087-41290577602370-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71111052-1638202589649043-36698753333786-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/logo-fblogo-blueprint.png" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71681851-1637967996339169-74155607909015.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>


    <footer class="bg-brand-bg border-t border-white/10 py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col md:flex-row justify-between gap-8">
          <div>
            <p class="font-display font-extrabold text-lg text-white">Birchwood Boarding Kennels</p>
            <p class="mt-2 text-white/70 text-sm">115B Tile Kiln Ln  Bexley DA5 2BD</p>
            <p class="mt-2"><a href="tel:+441322631996" class="text-brand-accent hover:underline text-sm">+441322631996</a></p>
            
          </div>
          
          <nav class="flex flex-wrap gap-6">
            <a href="/P3524" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Home</a>
            <a href="/P3524/services" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Services</a>
            <a href="/P3524/gallery" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Gallery</a>
            <a href="/P3524/contact" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10">
          <p class="text-white/40 text-xs">&copy; 2026 Birchwood Boarding Kennels. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
