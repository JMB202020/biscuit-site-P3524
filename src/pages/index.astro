---
import '../styles/site.css';
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redesign Preview | Birchwood Boarding Kennels</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/P3524/fonts/nunito-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/P3524/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="bg-brand-bg">

    <!-- Preview banner -->
    <div class="bg-brand-accent text-black py-2 px-4 text-center text-sm">
      <div class="max-w-4xl mx-auto flex items-center justify-center gap-3 flex-wrap">
        <span>Preview for <strong>Birchwood Boarding Kennels</strong> by <strong>Biscuit Web</strong></span>
        <a href="https://biscuitweb.co.uk/activate?id=P3524&name=Birchwood%20Boarding%20Kennels" class="inline-flex items-center px-4 py-1 bg-black text-brand-accent font-bold text-xs rounded-full hover:opacity-80 transition-opacity shrink-0">
          Like it? Just &pound;20/month
        </a>
      </div>
    </div>

    <!-- Nav -->
    <header class="bg-brand-bg/95 backdrop-blur-sm border-b border-white/10 sticky top-0 z-40">
      <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
        <a href="/P3524" class="font-display font-extrabold text-xl text-white">🐾 Birchwood Boarding Kennels</a>
        <button class="md:hidden p-2 text-white/70" onclick="document.getElementById('mobile-nav-P3524').classList.toggle('hidden')" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        </button>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/P3524" class="text-sm text-brand-accent font-semibold transition-colors">Home</a>
          <a href="/P3524/services" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Services</a>
          <a href="/P3524/gallery" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Gallery</a>
          <a href="/P3524/contact" class="text-sm text-white/70 hover:text-brand-accent font-semibold transition-colors">Contact</a>
          <a href="/P3524/contact" class="inline-flex items-center px-5 py-2 bg-brand-accent text-black font-display font-bold text-sm rounded hover:opacity-90 transition-opacity">Get in touch</a>
        </nav>
      </div>
      <nav id="mobile-nav-P3524" class="hidden md:hidden px-6 pb-4 space-y-3">
        <a href="/P3524" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Home</a>
        <a href="/P3524/services" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Services</a>
        <a href="/P3524/gallery" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Gallery</a>
        <a href="/P3524/contact" class="text-white/70 block text-sm font-semibold hover:text-brand-accent">Contact</a>
        <a href="/P3524/contact" class="block px-5 py-2.5 bg-brand-accent text-black font-display font-bold text-sm rounded text-center hover:opacity-90 transition-opacity">Get in touch</a>
      </nav>
    </header>


    <section class="bg-brand-bg py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 bg-brand-accent/10 text-brand-accent"><span>📍</span> Bexley</p>
            <h1 class="font-display font-extrabold text-3xl sm:text-5xl lg:text-6xl text-white leading-tight tracking-tight">Birchwood Boarding Kennels</h1>
            <p class="mt-6 text-lg sm:text-xl text-white/70 max-w-lg">Morning and Happy New Year to all of our customers! We’ve been made aware that our phone line is down and are in contact with Sky to get this resolved asap. Feel free to message us on here for anything!</p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/P3524/contact" class="inline-flex items-center px-6 py-3 sm:px-8 sm:py-4 bg-brand-accent text-black font-display font-bold text-base rounded-xl hover:opacity-90 transition-all">Get in touch</a>
              <a href="tel:+441322631996" class="inline-flex items-center px-6 py-3 sm:px-8 sm:py-4 border-2 border-brand-accent text-brand-accent font-display font-bold text-base rounded-xl hover:bg-brand-accent/5 transition-all">+441322631996</a>
            </div>
          </div>
          
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <img src="/P3524/images/36268627-1254930294642943-15324817231980-2.jpg" alt="" class="w-full h-auto object-cover" fetchpriority="high" />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-brand-bg border-y border-white/5 py-20">
      <div class="mx-auto max-w-7xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-white mb-10 text-center">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
          
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/510576472-3508512225951394-3562635743975-2.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/119933414-2004354253033873-3162195168049-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/120065753-2004354243033874-2413520240679-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="rounded-xl overflow-hidden bg-white/5 aspect-square">
            <img src="/P3524/images/71773928-1638202129649089-52782207046034-3.jpg" alt="" class="w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section class="bg-brand-bg border-y border-white/5 py-20">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display font-extrabold text-3xl text-white mb-10 text-center">Get in Touch</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="space-y-4">
            <p class="text-white text-lg"><strong>Phone:</strong> <a href="tel:+441322631996" class="text-brand-accent hover:underline">+441322631996</a></p>
            
            <p class="text-white text-lg"><strong>Address:</strong> 115B Tile Kiln Ln  Bexley DA5 2BD</p>
            <div class="rounded-xl overflow-hidden mt-2">
              <iframe src="https://www.google.com/maps?q=115B%20Tile%20Kiln%20Ln%20%20Bexley%20DA5%202BD&output=embed" width="100%" height="200" style="border:0" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Map showing Birchwood Boarding Kennels"></iframe>
            </div>
          </div>
          <form action="/api/contact" method="POST" class="bg-white/5 border border-white/10 rounded-lg p-8 space-y-4">
            <input type="hidden" name="_site_id" value="P3524" />
            <input type="hidden" name="_business_name" value="Birchwood Boarding Kennels" />
            <input type="hidden" name="_business_email" value="" />
            <div style="position:absolute;left:-9999px" aria-hidden="true"><input type="text" name="_hp" tabindex="-1" autocomplete="off" /></div>
            <div>
              <label class="text-white/70 text-sm font-semibold block mb-1">Name</label>
              <input type="text" name="name" required class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-white/5 text-white text-sm outline-none focus:border-brand-accent" placeholder="Your name" />
            </div>
            <div>
              <label class="text-white/70 text-sm font-semibold block mb-1">Email</label>
              <input type="email" name="email" required class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-white/5 text-white text-sm outline-none focus:border-brand-accent" placeholder="Your email" />
            </div>
            <div>
              <label class="text-white/70 text-sm font-semibold block mb-1">Phone</label>
              <input type="tel" name="phone" class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-white/5 text-white text-sm outline-none focus:border-brand-accent" placeholder="Your phone number (optional)" />
            </div>
            <div>
              <label class="text-white/70 text-sm font-semibold block mb-1">Message</label>
              <textarea rows="4" name="message" required class="w-full px-4 py-2.5 rounded-lg border border-white/10 bg-white/5 text-white text-sm outline-none focus:border-brand-accent resize-vertical" placeholder="How can we help?"></textarea>
            </div>
            <button type="submit" class="w-full px-6 py-3 bg-brand-accent text-black font-display font-bold text-sm rounded-lg hover:opacity-90 transition-opacity">Send Message</button>
            <script>if(location.search.includes('submitted=true')){document.currentScript.previousElementSibling.insertAdjacentHTML('afterend','<p style="text-align:center;color:#059669;font-weight:600;font-size:0.9rem;margin-top:8px">Thanks! Your message has been sent.</p>');document.currentScript.previousElementSibling.previousElementSibling.disabled=true;document.currentScript.previousElementSibling.previousElementSibling.textContent='Sent';}</script>
          </form>
        </div>
      </div>
    </section>


    <footer class="bg-brand-bg border-t border-white/10 py-12">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col md:flex-row justify-between gap-8">
          <div>
            <p class="font-display font-extrabold text-lg text-white">Birchwood Boarding Kennels</p>
            <p class="mt-2 text-white/70 text-sm">115B Tile Kiln Ln  Bexley DA5 2BD</p>
            <p class="mt-2"><a href="tel:+441322631996" class="text-brand-accent hover:underline text-sm">+441322631996</a></p>
            
          </div>
          
          <nav class="flex flex-wrap gap-6">
            <a href="/P3524" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Home</a>
            <a href="/P3524/services" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Services</a>
            <a href="/P3524/gallery" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Gallery</a>
            <a href="/P3524/contact" class="text-white/70 hover:text-brand-accent text-sm transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10">
          <p class="text-white/40 text-xs">&copy; 2026 Birchwood Boarding Kennels. All rights reserved.</p>
        </div>
      </div>
    </footer>

  </body>
</html>
